)
# Nouns, but need to add verb, pronoun, and adjective agreement rules as well based on the agent.
# Add second and third person examples.
# In classical arabic no engish, but may happen in gulf settings.

_SUPPORTED_LANGUAGES = _json.loads(os.getenv("AGENT_SUPPORTED_LANGUAGES", '["en"]'))

_FINAL_NOTE_LINES = {
    "en": "English → English only",
    "hi": "pure Devanagari → full Hindi, mixed → same mix",
    "ar": "Arabic → respond in Modern Standard Arabic (MSA / الفصحى) only, every word — no dialects, no English fillers, no parenthetical translations, no mixed terms."
}
_FINAL_NOTE = (
    " | ".join([_FINAL_NOTE_LINES[lang] for lang in _SUPPORTED_LANGUAGES if lang in _FINAL_NOTE_LINES])
)

_LANGUAGE_POLICIES = {
    "en": "Customer in English → respond in English only",
    "hi": "Customer in pure Devanagari Hindi → respond fully in Devanagari, never romanized\n    - Customer in mixed (Roman + Devanagari) → same mix — English words Roman, Hindi words Devanagari",
    "ar": "Customer in Arabic → respond in Arabic only"
}

_LANGUAGE_POLICY_LINES = "\n    - ".join([
    _LANGUAGE_POLICIES[lang]
    for lang in _SUPPORTED_LANGUAGES
    if lang in _LANGUAGE_POLICIES
])

_LANGUAGE_POLICY = f"""
    Warm, conversational, short sentences. Never robotic or scripted. Always mirror the customer's script exactly:
    - {_LANGUAGE_POLICY_LINES}
    """

MIXTRAL_ROW_TEXT_PROMPT_TMPL = """
[INST]
####
Convert each row of the given table after <<<>>> into concise descriptive text.

1. **Describe Every Row**: Include a description for each row in the table.
2. **Single JSON Object per Row**: Capture all values from a row within one JSON object.
3. **Ignore Irrelevant Data**: Exclude any junk or irrelevant values or entries.
4. **Table-Only Description**: Only describe what is provided in the table.
5. **Expand Abbreviations**: Expand abbreviations (e.g., FY, YoY, QoQ) and include the abbreviation in brackets.
6. **No Extra Explanations**: Only provide the required information without additional commentary.
7. **Output as JSON**: Format the results as a list of JSON objects, with each row described separately.

Example output:
{{ "description":[
  {{"row": "......"}},
  {{"row": "......"}},
  ...
]
}}
