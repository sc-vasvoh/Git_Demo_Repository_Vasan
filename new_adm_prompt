def _load_supported_languages():
    raw_supported_languages = os.getenv("AGENT_SUPPORTED_LANGUAGES", '["en"]')
    try:
        parsed_supported_languages = _json.loads(raw_supported_languages)
    except _json.JSONDecodeError:
        return ["en"]
    return parsed_supported_languages if isinstance(parsed_supported_languages, list) else ["en"]

